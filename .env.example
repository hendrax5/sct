# ================================================================================
# .env.example — Environment Configuration Template
# ================================================================================
# COPY THIS FILE TO .env AND UPDATE ALL VALUES
# NEVER commit .env to git (add to .gitignore)
# ⚠️ WAJIB change all default values sebelum deployment ke production!
# ================================================================================

# ===== APPLICATION =====
NODE_ENV=development
APP_PORT=3000
APP_NAME=Ecommerce UMKM
APP_URL=http://localhost:3000

# ===== AUTHENTICATION =====
# Generate dengan: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-this-in-production-12345
NEXTAUTH_URL=http://localhost:3000

# ===== DATABASE (PostgreSQL) =====
# Free tier: Neon (https://neon.tech)
DB_HOST=db
DB_PORT=5432
DB_USER=appuser
DB_PASS=changeme
DB_NAME=ecommerce
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://appuser:changeme@db:5432/ecommerce

# ===== REDIS CACHE =====
# Free tier: Redis Cloud atau local instance
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=redispass
REDIS_URL=redis://:redispass@redis:6379

# ===== XENDIT PAYMENT GATEWAY =====
# Sign up: https://dashboard.xendit.co
# Get API keys di: Settings → API Keys
XENDIT_API_KEY=xnd_development_xxxxxxxxxxxxxxxxxxxx
XENDIT_WEBHOOK_KEY=xnd_webhook_xxxxxxxxxxxxxxxxxxxx
XENDIT_CALLBACK_URL=http://localhost:3000/api/payments/xendit/callback

# ===== SENDGRID EMAIL SERVICE =====
# Free tier: 100 emails/day
# Sign up: https://sendgrid.com
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@ecommerce.example.com
SENDGRID_FROM_NAME=Ecommerce UMKM

# ===== RAJAONGKIR SHIPPING API =====
# Free tier: 10 requests/day
# Sign up: https://rajaongkir.com/akun/daftar
RAJAONGKIR_API_KEY=your-rajaongkir-api-key-here
RAJAONGKIR_COURIER=jne,tiki,pos

# ===== GRAFANA MONITORING =====
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASS=admin123

# ===== ADMINER DATABASE MANAGEMENT =====
ADMINER_PORT=8080

# ===== STORAGE =====
# Image uploads, product images, etc
# Option 1: Vercel Blob (recommended for Vercel deployments)
# BLOB_READ_WRITE_TOKEN=vercel_blob_token_xxx

# Option 2: AWS S3 (if self-hosted)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=ecommerce-umkm-bucket
# AWS_S3_REGION=ap-southeast-1

# ===== ERROR TRACKING =====
# Sentry: https://sentry.io
SENTRY_DSN=https://xxxxxxxxxxxxx@xxxxx.ingest.sentry.io/xxxxxx

# ===== ANALYTICS =====
# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===== FEATURE FLAGS =====
# Enable/disable features for A/B testing
ENABLE_WISHLIST=true
ENABLE_REVIEWS=false
ENABLE_AFFILIATE=false
ENABLE_2FA=false

# ===== SECURITY =====
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== DEVELOPMENT =====
# Enable debug logs
DEBUG=ecommerce:*

# ===== PRODUCTION ONLY =====
# Uncomment these for production deployment

# HTTPS enforcement
# ENFORCE_HTTPS=true

# CORS allowed origins
# CORS_ORIGINS=https://ecommerce.example.com,https://www.ecommerce.example.com

# Database connection pool
# DB_POOL_MIN=5
# DB_POOL_MAX=20

# Cache TTL (seconds)
# CACHE_PRODUCT_TTL=3600
# CACHE_CATEGORY_TTL=86400

# ================================================================================
# SETUP INSTRUCTIONS
# ================================================================================
# 1. Copy this file: cp .env.example .env
# 2. Update all values (especially secrets)
# 3. For development: docker compose up -d
# 4. Check services are healthy: docker compose ps
# 5. View logs: docker compose logs -f app
#
# IMPORTANT LINKS:
# - App: http://localhost:3000
# - Grafana: http://localhost:3001 (admin/admin123)
# - Adminer: http://localhost:8080
# - Database: postgresql://appuser:changeme@localhost:5432/ecommerce
# ================================================================================
